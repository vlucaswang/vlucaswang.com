---
interface Props {
  title: string;
  description: string;
  pubDate: string;
  url: string;
}

const { title, description, pubDate, url } = Astro.props;
---

<article class="group relative py-6 border-b-2 border-dashed border-[var(--accent)] last:border-0">
  <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-8">
    <time class="text-xs font-bold text-[var(--foreground)] opacity-70 uppercase tracking-widest shrink-0 w-32">
      :: {pubDate} ::
    </time>
    <div class="space-y-3">
      <h3 class="font-bold tracking-tight group-hover:bg-[var(--accent)] group-hover:text-[var(--background)] transition-all inline-block px-1 m-0!">
        <a href={url}>
          <span class="absolute inset-0"></span>
          {title}
        </a>
      </h3>
      <p class="text-[var(--foreground)] opacity-80 leading-relaxed max-w-2xl m-0!">
        {description}
      </p>
      <div class="text-[var(--accent)] font-bold uppercase tracking-widest text-xs">
        [ Read Post ]
      </div>
    </div>
  </div>
</article>
