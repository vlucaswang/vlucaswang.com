---
interface Props {
  title: string;
  description: string;
  url: string;
  tags: string[];
}

const { title, description, url, tags } = Astro.props;
---

<div class="p-6 border-4 border-[var(--accent)] bg-[var(--background)] hover:shadow-[4px_4px_0px_0px_var(--accent)] transition-all">
  <h3 class="font-bold mb-4 uppercase tracking-tighter m-0!">&gt; {title}</h3>
  <p class="text-[var(--foreground)] opacity-90 mb-6 leading-relaxed italic m-0!">{description}</p>
  <div class="flex flex-wrap gap-2 mb-6">
    {tags.map((tag) => (
      <span class="px-2 py-0.5 text-[10px] font-bold border-2 border-[var(--accent)] text-[var(--accent)] uppercase tracking-wider">
        {tag}
      </span>
    ))}
  </div>
  <a href={url} class="text-xs font-bold bg-[var(--accent)] text-[var(--background)] px-3 py-1.5 hover:opacity-90 inline-flex items-center gap-2 group transition-all">
    [ VIEW_PROJECT ]
    <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
  </a>
</div>
