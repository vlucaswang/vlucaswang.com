---
const today = new Date();
---

<footer class="mt-auto py-12 border-t border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-950">
  <div class="container mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-12">
    <!-- Explore -->
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider mb-4">Explore</h3>
      <ul class="space-y-3">
        <li><a href="/blog" class="text-gray-600 dark:text-gray-400 hover:text-blue-600 transition-colors">Blog</a></li>
        <li><a href="/about" class="text-gray-600 dark:text-gray-400 hover:text-blue-600 transition-colors">About</a></li>
        <li><a href="/uses" class="text-gray-600 dark:text-gray-400 hover:text-blue-600 transition-colors">Uses</a></li>
        <li><a href="/resume" class="text-gray-600 dark:text-gray-400 hover:text-blue-600 transition-colors">Resume</a></li>
      </ul>
    </div>

    <!-- Things I've Made -->
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider mb-4">Things I've Made</h3>
      <ul class="space-y-3">
        <li><a href="/projects" class="text-gray-600 dark:text-gray-400 hover:text-blue-600 transition-colors">Portfolio</a></li>
        <li><a href="https://github.com/vlucaswang" target="_blank" rel="noopener noreferrer" class="text-gray-600 dark:text-gray-400 hover:text-blue-600 transition-colors">Open Source</a></li>
      </ul>
    </div>

    <!-- Let's Connect -->
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider mb-4">Let's Connect</h3>
      <ul class="space-y-3">
        <li><a href="https://github.com/vlucaswang" target="_blank" rel="noopener noreferrer" class="text-gray-600 dark:text-gray-400 hover:text-blue-600 transition-colors">GitHub</a></li>
        <li><a href="https://linkedin.com/in/vlucaswang" target="_blank" rel="noopener noreferrer" class="text-gray-600 dark:text-gray-400 hover:text-blue-600 transition-colors">LinkedIn</a></li>
        <li><a href="/rss.xml" class="text-gray-600 dark:text-gray-400 hover:text-blue-600 transition-colors">RSS Feed</a></li>
      </ul>
    </div>
  </div>
  
  <div class="container mx-auto px-4 mt-12 pt-8 border-t border-gray-200 dark:border-gray-800 flex flex-col md:flex-row justify-between items-center text-sm text-gray-500 dark:text-gray-500">
    <p>&copy; {today.getFullYear()} Lucas Wang. All rights reserved.</p>
    <p class="mt-4 md:mt-0">Built with <a href="https://astro.build" class="hover:underline">Astro</a> & <a href="https://tailwindcss.com" class="hover:underline">Tailwind CSS</a></p>
  </div>
</footer>
