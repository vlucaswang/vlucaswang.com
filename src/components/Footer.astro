---
const today = new Date();
---

<footer class="py-12 border-t border-dashed border-[var(--accent)] mt-auto">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
    <!-- Explore -->
    <div>
      <h3 class="font-bold uppercase tracking-widest mb-6 text-[var(--accent)] underline decoration-dotted underline-offset-8">Explore</h3>
      <ul class="space-y-3">
        <li><a href="/blog" class="hover:bg-[var(--accent)] hover:text-[var(--background)] px-1 transition-all inline-block">&gt; Blog</a></li>
        <li><a href="/about" class="hover:bg-[var(--accent)] hover:text-[var(--background)] px-1 transition-all inline-block">&gt; About</a></li>
        <li><a href="/uses" class="hover:bg-[var(--accent)] hover:text-[var(--background)] px-1 transition-all inline-block">&gt; Uses</a></li>
        <li><a href="/resume" class="hover:bg-[var(--accent)] hover:text-[var(--background)] px-1 transition-all inline-block">&gt; Resume</a></li>
      </ul>
    </div>

    <!-- Things I've Made -->
    <div>
      <h3 class="font-bold uppercase tracking-widest mb-6 text-[var(--accent)] underline decoration-dotted underline-offset-8">Projects</h3>
      <ul class="space-y-3">
        <li><a href="/projects" class="hover:bg-[var(--accent)] hover:text-[var(--background)] px-1 transition-all inline-block">&gt; Portfolio</a></li>
        <li><a href="https://github.com/vlucaswang" target="_blank" rel="noopener noreferrer" class="hover:bg-[var(--accent)] hover:text-[var(--background)] px-1 transition-all inline-block">&gt; Open Source</a></li>
      </ul>
    </div>

    <!-- Let's Connect -->
    <div>
      <h3 class="font-bold uppercase tracking-widest mb-6 text-[var(--accent)] underline decoration-dotted underline-offset-8">Connect</h3>
      <ul class="space-y-3">
        <li><a href="https://github.com/vlucaswang" target="_blank" rel="noopener noreferrer" class="hover:bg-[var(--accent)] hover:text-[var(--background)] px-1 transition-all inline-block">&gt; GitHub</a></li>
        <li><a href="https://linkedin.com/in/vlucaswang" target="_blank" rel="noopener noreferrer" class="hover:bg-[var(--accent)] hover:text-[var(--background)] px-1 transition-all inline-block">&gt; LinkedIn</a></li>
        <li><a href="/rss.xml" class="hover:bg-[var(--accent)] hover:text-[var(--background)] px-1 transition-all inline-block">&gt; RSS Feed</a></li>
      </ul>
    </div>
  </div>
  
  <div class="mt-12 pt-8 border-t border-[var(--accent)] flex flex-col md:flex-row justify-between items-center text-xs opacity-70 uppercase tracking-widest">
    <p>&copy; {today.getFullYear()} Lucas Wang. :: all rights reserved ::</p>
    <p class="mt-4 md:mt-0">Built with <a href="https://astro.build" class="underline">Astro</a> :: theme inspired by <a href="https://github.com/panr/hugo-theme-terminal" class="underline">Terminal</a></p>
  </div>
</footer>
