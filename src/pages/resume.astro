---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resume | Lucas Wang">
  <div class="text-center">
    <h1 class="font-black uppercase tracking-tighter mb-8 underline decoration-dotted underline-offset-[12px] m-0!">
      &gt; RESUME
    </h1>
    
    <div class="p-8 border-4 border-[var(--accent)] bg-[var(--background)] shadow-[8px_8px_0px_0px_var(--accent)] max-w-2xl mx-auto">
      <p class="font-bold mb-8 uppercase tracking-widest text-sm m-0!">
        :: looking for my full background? ::
      </p>
      
      <div class="flex justify-center mb-8">
        <a href="/resume.pdf" class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--accent)] text-[var(--background)] font-black text-sm uppercase tracking-[0.1em] hover:opacity-90 transition-all">
          [ DOWNLOAD_PDF ]
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </a>
      </div>
      
      <div class="space-y-4 opacity-70 font-bold uppercase tracking-widest text-[10px]">
        <p class="m-0!">&gt; generated via custom rendercv engine</p>
        <p class="m-0!">&gt; platform: cloudflare pages</p>
        <p class="m-0!">&gt; last updated: march 2026</p>
      </div>
    </div>
    
    <p class="mt-12 text-[var(--accent)] font-bold italic text-xs m-0!">
      "Engineering secure, scalable production systems at the edge."
    </p>
  </div>
</Layout>
