---
import Layout from '../layouts/Layout.astro';

const tools = [
  { category: 'Hardware', items: ['MacBook Pro M3 Max', 'Sony WH-1000XM5', 'Keychron K2'] },
  { category: 'Software', items: ['VS Code', 'iTerm2', 'Postman', 'Docker'] },
  { category: 'Daily Carry', items: ['iPhone 15 Pro', 'Kindle Paperwhite'] },
];
---

<Layout title="Uses | Lucas Wang">
  <div class="max-w-3xl mx-auto py-12 md:py-24">
    <h1 class="text-4xl md:text-6xl font-black tracking-tight mb-8">Uses</h1>
    <p class="text-xl text-gray-600 dark:text-gray-400 mb-12">
      A list of tools, gear, and software I use daily.
    </p>
    
    <div class="space-y-12">
      {tools.map((section) => (
        <div>
          <h2 class="text-2xl font-bold mb-6 border-b border-gray-100 dark:border-gray-800 pb-2">{section.category}</h2>
          <ul class="grid gap-4 md:grid-cols-2">
            {section.items.map((item) => (
              <li class="p-4 bg-gray-50 dark:bg-gray-800 rounded-xl font-medium">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</Layout>
