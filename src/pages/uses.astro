---
import Layout from '../layouts/Layout.astro';

const tools = [
  { category: 'HARDWARE', items: [':: MacBook Pro M3 Max', ':: Sony WH-1000XM5', ':: Keychron K2'] },
  { category: 'SOFTWARE', items: [':: VS Code + Fira Code', ':: iTerm2 + Oh My Zsh', ':: Postman / Docker'] },
  { category: 'DAILY_CARRY', items: [':: iPhone 15 Pro', ':: Kindle Paperwhite'] },
];
---

<Layout title="Uses | Lucas Wang">
  <div class="max-w-3xl mx-auto py-12 md:py-24">
    <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tighter mb-12 underline decoration-dotted underline-offset-[16px]">
      &gt; USES
    </h1>
    <p class="text-xl text-[var(--foreground)] opacity-90 mb-16 font-bold italic">
      :: A list of tools, gear, and software I use daily ::
    </p>
    
    <div class="space-y-20">
      {tools.map((section) => (
        <div class="group">
          <h2 class="text-3xl font-bold mb-8 uppercase tracking-[0.2em] text-[var(--accent)] flex items-center gap-4">
            <span class="bg-[var(--accent)] text-[var(--background)] px-2">#</span>
            {section.category}
          </h2>
          <ul class="grid gap-6 md:grid-cols-2">
            {section.items.map((item) => (
              <li class="p-6 border-2 border-dashed border-[var(--accent)] hover:bg-[var(--accent)] hover:text-[var(--background)] font-bold transition-all uppercase tracking-widest text-sm">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    
    <div class="mt-24 p-8 border-4 border-[var(--accent)] bg-[var(--foreground)]/5 text-center">
      <p class="font-bold uppercase tracking-widest text-sm opacity-70">
        :: updated periodically ::
      </p>
    </div>
  </div>
</Layout>
