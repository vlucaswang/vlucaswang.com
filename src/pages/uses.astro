---
import Layout from '../layouts/Layout.astro';

const tools = [
  { category: 'HARDWARE', items: [':: MacBook Pro M3 Max', ':: Sony WH-1000XM5', ':: Keychron K2'] },
  { category: 'SOFTWARE', items: [':: VS Code + Fira Code', ':: iTerm2 + Oh My Zsh', ':: Postman / Docker'] },
  { category: 'DAILY_CARRY', items: [':: iPhone 15 Pro', ':: Kindle Paperwhite'] },
];
---

<Layout title="Uses | Lucas Wang">
  <div>
    <h1 class="font-black uppercase tracking-tighter mb-8 underline decoration-dotted underline-offset-[12px] m-0!">
      &gt; USES
    </h1>
    <p class="text-sm text-[var(--foreground)] opacity-90 mb-12 font-bold italic m-0!">
      :: A list of tools, gear, and software I use daily ::
    </p>
    
    <div class="space-y-12">
      {tools.map((section) => (
        <div class="group">
          <h2 class="font-bold mb-6 uppercase tracking-[0.2em] text-[var(--accent)] flex items-center gap-2 m-0!">
            <span class="bg-[var(--accent)] text-[var(--background)] px-1">#</span>
            {section.category}
          </h2>
          <ul class="grid gap-4 md:grid-cols-2 m-0!">
            {section.items.map((item) => (
              <li class="p-4 border-2 border-dashed border-[var(--accent)] hover:bg-[var(--accent)] hover:text-[var(--background)] font-bold transition-all uppercase tracking-widest text-[10px]">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    
    <div class="mt-16 p-6 border-4 border-[var(--accent)] bg-[var(--foreground)]/5 text-center">
      <p class="font-bold uppercase tracking-widest text-[10px] opacity-70 m-0!">
        :: updated periodically ::
      </p>
    </div>
  </div>
</Layout>
