---
import Layout from '../layouts/Layout.astro';
import BlogPost from '../components/BlogPost.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const featuredPosts = posts.slice(0, 2).map(post => ({
  title: post.data.title,
  description: post.data.description,
  pubDate: post.data.pubDate.toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' }),
  url: `/blog/${post.id}`
}));

const projects = await getCollection('projects');
const featuredProjects = projects.map(p => ({
  title: p.data.title,
  description: p.data.description,
  url: p.data.url,
  tags: p.data.tags
}));
---

<Layout title="Lucas Wang | Software Engineer">
  <section class="py-12 md:py-24">
    <div class="max-w-3xl">
      <h1 class="text-5xl md:text-7xl font-bold tracking-tighter mb-8 leading-tight">
        &gt; I'M <span class="bg-[var(--accent)] text-[var(--background)] px-2">LUCAS WANG</span>
      </h1>
      <p class="text-xl md:text-2xl text-[var(--foreground)] mb-12 leading-relaxed max-w-2xl opacity-90">
        Senior Platform Engineer building secure, scalable systems. 
        Specializing in infrastructure, observability, and developer experience.
      </p>
      <div class="flex flex-wrap gap-6">
        <a href="/about" class="px-8 py-3 border-4 border-[var(--accent)] font-bold uppercase tracking-widest hover:bg-[var(--accent)] hover:text-[var(--background)] transition-all">
          [ Learn More ]
        </a>
        <a href="/projects" class="px-8 py-3 border-4 border-[var(--accent)] font-bold uppercase tracking-widest hover:bg-[var(--accent)] hover:text-[var(--background)] transition-all">
          [ Portfolio ]
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 border-t-4 border-[var(--accent)]">
    <div class="flex justify-between items-baseline mb-12">
      <h2 class="text-3xl font-bold uppercase tracking-widest underline decoration-dotted underline-offset-8">Featured Posts</h2>
      <a href="/blog" class="font-bold text-[var(--accent)] hover:underline">:: View All ::</a>
    </div>
    <div class="space-y-12">
      {featuredPosts.map((post) => (
        <BlogPost {...post} />
      ))}
    </div>
  </section>

  <section class="py-20 border-t-4 border-[var(--accent)]">
    <div class="flex justify-between items-baseline mb-12">
      <h2 class="text-3xl font-bold uppercase tracking-widest underline decoration-dotted underline-offset-8">Recent Projects</h2>
      <a href="/projects" class="font-bold text-[var(--accent)] hover:underline">:: Portfolio ::</a>
    </div>
    <div class="grid gap-8 md:grid-cols-2">
      {featuredProjects.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>
</Layout>
