---
import Layout from '../layouts/Layout.astro';
import BlogPost from '../components/BlogPost.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const featuredPosts = [
  {
    title: 'Building a Portfolio with Astro and Tailwind',
    description: 'A guide on how to create a modern, performant portfolio site.',
    pubDate: '2 March 2024',
    url: '/blog/astro-tailwind-portfolio',
  },
  {
    title: 'Why I switched to Astro',
    description: 'Exploring the benefits of static site generation and islands architecture.',
    pubDate: '15 Feb 2024',
    url: '/blog/why-astro',
  },
];

const projects = await getCollection('projects');
const featuredProjects = projects.map(p => ({
  title: p.data.title,
  description: p.data.description,
  url: p.data.url,
  tags: p.data.tags
}));
---

<Layout title="Lucas Wang | Software Engineer">
	<section class="py-12 md:py-32">
    <div class="max-w-3xl">
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter mb-8 leading-[1.1]">
        I'm <span class="text-blue-600 dark:text-blue-500">Lucas Wang</span>, a software engineer building the future.
      </h1>
      <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 mb-12 leading-relaxed max-w-2xl">
        I specialize in distributed systems, frontend architecture, and developer tools. 
        Currently focusing on making the web faster and more accessible for everyone.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/about" class="px-8 py-4 bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-bold rounded-full hover:scale-105 transition-all">
          More about me
        </a>
        <a href="https://github.com/vlucaswang" target="_blank" rel="noopener noreferrer" class="px-8 py-4 bg-white dark:bg-gray-900 text-gray-900 dark:text-white border-2 border-gray-200 dark:border-gray-800 font-bold rounded-full hover:scale-105 transition-all">
          GitHub
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 border-t border-gray-100 dark:border-gray-800">
    <div class="flex justify-between items-end mb-12">
      <h2 class="text-3xl font-black tracking-tight">Featured Posts</h2>
      <a href="/blog" class="font-bold text-blue-600 dark:text-blue-400 group flex items-center gap-1">
        All posts <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
      </a>
    </div>
    <div class="divide-y divide-gray-100 dark:divide-gray-800">
      {featuredPosts.map((post) => (
        <BlogPost {...post} />
      ))}
    </div>
  </section>

  <section class="py-20 border-t border-gray-100 dark:border-gray-800">
    <div class="flex justify-between items-end mb-12">
      <h2 class="text-3xl font-black tracking-tight">Recent Projects</h2>
      <a href="/projects" class="font-bold text-blue-600 dark:text-blue-400 group flex items-center gap-1">
        Portfolio <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
      </a>
    </div>
    <div class="grid gap-8 md:grid-cols-2">
      {featuredProjects.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>
</Layout>
