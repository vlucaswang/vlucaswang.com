---
import { getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/404');
}

const post = await getEntry('blog', id);

if (!post) {
  return Astro.redirect('/404');
}

const { Content } = await render(post);
const pubDate = post.data.pubDate.toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' });
---

<Layout title={`${post.data.title} | Lucas Wang`}>
  <article>
    <header class="mb-10 border-b-4 border-[var(--accent)] pb-6">
      <time class="font-bold text-[var(--accent)] mb-2 block uppercase tracking-[0.2em] text-xs">
        :: {pubDate} ::
      </time>
      <h1 class="font-black uppercase tracking-tighter mb-4 leading-tight m-0!">
        {post.data.title}
      </h1>
      <p class="opacity-80 italic font-bold text-sm m-0!">
        &gt; {post.data.description}
      </p>
    </header>
    
    <div class="prose prose-sm dark:prose-invert max-w-none 
      prose-headings:text-[var(--accent)] prose-headings:font-black prose-headings:uppercase prose-headings:tracking-tighter
      prose-a:text-[var(--accent)] prose-a:underline prose-a:decoration-dotted
      prose-blockquote:border-[var(--accent)] prose-blockquote:bg-[var(--foreground)]/5 prose-blockquote:p-4
      prose-img:border-2 prose-img:border-[var(--accent)]
      prose-code:bg-[var(--foreground)]/10 prose-code:px-1 prose-code:before:content-none prose-code:after:content-none
      text-[var(--foreground)] opacity-95">
      <Content />
    </div>
    
    <footer class="mt-16 pt-6 border-t-2 border-dashed border-[var(--accent)]">
      <a href="/blog" class="font-bold text-[var(--accent)] uppercase tracking-widest hover:bg-[var(--accent)] hover:text-[var(--background)] px-2 py-1 transition-all text-xs">
        [ &larr; BACK_TO_BLOG ]
      </a>
    </footer>
  </article>
</Layout>
