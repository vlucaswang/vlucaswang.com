---
import { getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/404');
}

const post = await getEntry('blog', id);

if (!post) {
  return Astro.redirect('/404');
}

const { Content } = await render(post);
const pubDate = post.data.pubDate.toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' });
---

<Layout title={`${post.data.title} | Lucas Wang`}>
  <article class="max-w-3xl mx-auto py-12">
    <header class="mb-12 border-b-4 border-[var(--accent)] pb-8">
      <time class="text-sm font-bold text-[var(--accent)] mb-4 block uppercase tracking-[0.3em]">
        :: {pubDate} ::
      </time>
      <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tighter mb-6 leading-tight">
        {post.data.title}
      </h1>
      <p class="text-xl opacity-80 italic font-bold">
        &gt; {post.data.description}
      </p>
    </header>
    
    <div class="prose prose-lg dark:prose-invert max-w-none 
      prose-headings:text-[var(--accent)] prose-headings:font-black prose-headings:uppercase prose-headings:tracking-tighter
      prose-a:text-[var(--accent)] prose-a:underline prose-a:decoration-dotted
      prose-blockquote:border-[var(--accent)] prose-blockquote:bg-[var(--foreground)]/5 prose-blockquote:p-6
      prose-img:border-4 prose-img:border-[var(--accent)]
      prose-code:bg-[var(--foreground)]/10 prose-code:px-1 prose-code:before:content-none prose-code:after:content-none
      text-[var(--foreground)] opacity-95">
      <Content />
    </div>
    
    <footer class="mt-20 pt-8 border-t-2 border-dashed border-[var(--accent)]">
      <a href="/blog" class="font-bold text-[var(--accent)] uppercase tracking-widest hover:bg-[var(--accent)] hover:text-[var(--background)] px-2 py-1 transition-all">
        [ &larr; BACK_TO_BLOG ]
      </a>
    </footer>
  </article>
</Layout>
